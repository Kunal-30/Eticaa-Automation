<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SSWebsite Test Suite" verbose="1" parallel="methods" thread-count="50">
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <!-- Existing Super Admin test stays as-is -->
    <test name="Super Admin Tests">
        <classes>
            <class name="testPackage.superadmintest">
                <methods>
                    <include name="create_And_Verify_CustomersAndUsers_ActivationAndDeactivation"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- New Mixed Advanced Filters multi-user load test -->
    <test name="Mixed Advance Filters Load">
        <classes>
            <class name="testPackage.filters.mixed_advance_filter.MixedAdvanceFilterTest">
                <methods>
                    <include name="mixedAdvanceFilters_MultiUser_Load_FromUsersExcel"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>
