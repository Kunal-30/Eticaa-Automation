<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>
    </Appenders>
    <Loggers>
        <!-- Suppress TestNG internal logs -->
        <Logger name="org.testng.internal.Utils" level="ERROR" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <Logger name="org.testng" level="ERROR" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <!-- Suppress Selenium logs -->
        <Logger name="org.seleniumhq.selenium" level="ERROR" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <!-- Suppress other framework logs -->
        <Logger name="org.apache.http" level="ERROR" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <Root level="INFO">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>